# Vercel Postgres (auto-populated when you connect the DB in Vercel dashboard)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob (auto-populated when you add Blob storage in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=

# Admin auth - set these yourself
ADMIN_PASSWORD=change-me-to-something-strong
ADMIN_SESSION_SECRET=generate-a-random-32-char-string

# Resend - sign up at resend.com, add your API key
RESEND_API_KEY=
# Where inquiry notifications get sent
INQUIRY_NOTIFICATION_EMAIL=jay@example.com
# The "from" address (must be on a domain you've verified in Resend, or use onboarding@resend.dev for testing)
INQUIRY_FROM_EMAIL=onboarding@resend.dev

# Public site URL (used in emails, canonical tags, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
